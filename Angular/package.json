{
  "name": "biademo",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start4iis": "ng serve --configuration iis",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "e2e": "ng e2e",
    "clean": "npx prettier --write . --plugin=prettier-plugin-organize-imports && ng lint --fix",
    "build:iis": "ng build --configuration iis",
    "build:aot": "ng build --aot --base-href /BIADemo/App/ --configuration iis",
    "build:aot2": "ng build --aot --base-href /BIADemo2/App/ --output-path dist/BIADemo2 --configuration iis",
    "build:prod": "ng build --configuration production --base-href /BIADemo/App/",
    "build:prod2": "ng build --configuration production --base-href /BIADemo2/App/ --output-path dist/BIADemo2",
    "build:ocp": "ng build --configuration production,ocp",
    "build:rosa": "ng build --configuration production,rosa",
    "build:docker": "ng build --configuration docker",
    "build-bia-ng": "ng build bia-ng",
    "build-bia-ng:prod": "ng build bia-ng --configuration production",
    "deploy": "ng deploy --base-href=/BIADemo/",
    "styles": "dart compile-sass.dart ./src/assets/bia/primeng/bia/layout-primeng-bia.scss ./src/assets/bia/primeng/layout/styles/layout/layout.css --output-style compressed",
    "stats-compute": "ng build --configuration production --base-href /BIADemo/App/ --stats-json && esbuild-visualizer --metadata dist/BIADemo/stats.json --filename dist/BIADemo/stats.html",
    "stats-display": "start \"\" \"dist/BIADemo/stats.html\"",
    "stats": "npm run stats-compute && npm run stats-display"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.2",
    "@angular/cdk": "~21.2.1",
    "@angular/common": "~21.2.2",
    "@angular/compiler": "~21.2.2",
    "@angular/core": "~21.2.2",
    "@angular/forms": "~21.2.2",
    "@angular/platform-browser": "~21.2.2",
    "@angular/platform-browser-dynamic": "~21.2.2",
    "@angular/router": "~21.2.2",
    "@angular/service-worker": "~21.2.2",
    "@microsoft/signalr": "~10.0.0",
    "@ngrx/effects": "~21.0.1",
    "@ngrx/entity": "~21.0.1",
    "@ngrx/operators": "~21.0.1",
    "@ngrx/store": "~21.0.1",
    "@ngx-translate/core": "~17.0.0",
    "@primeuix/themes": "~2.0.3",
    "@types/file-saver": "~2.0.7",
    "date-fns": "~4.1.0",
    "deepmerge": "~4.3.1",
    "dexie": "~4.3.0",
    "file-saver": "~2.0.5",
    "jwt-decode": "~4.0.0",
    "keycloak-angular": "~21.0.0",
    "keycloak-js": "~26.2.3",
    "ngx-logger": "~5.0.12",
    "papaparse": "~5.5.2",
    "primeflex": "~4.0.0",
    "primeicons": "~7.0.0",
    "primeng": "~21.1.3",
    "quill": "~2.0.3",
    "rxjs": "~7.8.2",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.0",
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular-eslint/builder": "~21.2.0",
    "@angular-eslint/eslint-plugin": "~21.2.0",
    "@angular-eslint/eslint-plugin-template": "~21.2.0",
    "@angular-eslint/schematics": "~21.2.0",
    "@angular-eslint/template-parser": "~21.2.0",
    "@angular/build": "~21.2.1",
    "@angular/cli": "~21.2.1",
    "@angular/compiler-cli": "~21.2.2",
    "@angular/language-service": "~21.2.2",
    "@ngrx/store-devtools": "~21.0.1",
    "@types/node": "~25.3.0",
    "@types/papaparse": "~5.5.2",
    "@typescript-eslint/eslint-plugin": "~8.56.0",
    "@typescript-eslint/parser": "~8.56.0",
    "eslint": "~9.39.1",
    "eslint-config-prettier": "~10.1.5",
    "eslint-plugin-prettier": "~5.5.5",
    "ng-packagr": "~21.1.0",
    "prettier": "~3.8.1",
    "prettier-eslint": "~16.4.2",
    "prettier-plugin-organize-imports": "~4.3.0",
    "ts-node": "~10.9.2",
    "tslib": "~2.8.1",
    "typescript": "~5.9.3"
  }
}
